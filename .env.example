# HubSpot MCP auth app (Development → MCP Auth Apps)
HUBSPOT_MCP_CLIENT_ID=
HUBSPOT_MCP_CLIENT_SECRET=

# Must match a redirect URL registered on the MCP auth app
HUBSPOT_MCP_REDIRECT_URI=http://localhost:3000/oauth/callback

# Optional: override HubSpot MCP endpoint (default https://mcp.hubspot.com/)
# HUBSPOT_MCP_URL=https://mcp.hubspot.com/

# Path to a JSON file (not a directory). Default: ~/.config/hubspot-mcp-bridge/session.json
# HUBSPOT_MCP_TOKEN_PATH=/home/you/.config/hubspot-mcp-bridge/session.json

# One-shot exchange for `hubspot-mcp-bridge auth` (or pass --code / pipe stdin)
# HUBSPOT_MCP_AUTH_CODE=

# Headless runtime: inject tokens instead of reading the session file
# HUBSPOT_MCP_ACCESS_TOKEN=
# HUBSPOT_MCP_REFRESH_TOKEN=
